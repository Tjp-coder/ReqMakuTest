{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MakuBoot 机构列表响应结构",
  "type": "object",
  "required": ["code", "msg", "data"],
  "properties": {
    "code": { "type": "integer" },
    "msg":  { "type": "string" },
    "data": {
      "type": "array",
      "items": { "$ref": "#/definitions/org" }
    }
  },
  "definitions": {
    "org": {
      "type": "object",
      "required": ["id", "pid", "name", "sort"],
      "properties": {
        "id":       { "type": "integer" },
        "pid":      { "type": "integer" },
        "name":     { "type": "string" },
        "sort":     { "type": "integer" },
        "createTime": { "type": ["string", "null"] },
        "parentName": { "type": ["string", "null"] },
        "children": {
          "type": "array",
          "items": { "$ref": "#/definitions/org" }
        }
      }
    }
  }
}
