{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MakuBoot 登录成功响应结构",
  "description": "验证 /sys/auth/login 正向响应的字段结构和类型",
  "type": "object",
  "required": ["code", "msg", "data"],
  "properties": {
    "code": {
      "type": "integer",
      "description": "业务状态码，0 表示成功"
    },
    "msg": {
      "type": "string",
      "description": "响应消息"
    },
    "data": {
      "type": "object",
      "description": "登录成功后的 token 信息",
      "required": ["access_token"],
      "properties": {
        "access_token": {
          "type": "string",
          "minLength": 1,
          "description": "用于后续接口鉴权的 Bearer Token"
        }
      }
    }
  }
}
