# Maven 构建输出
target/

# Java 编译产物
*.class
*.jar
*.war

# Allure 测试原始结果（每次 mvn test 自动生成，不需要跟踪）
allure-results/

# IntelliJ IDEA - 以下文件存本地状态，不应共享
.idea/workspace.xml
.idea/tasks.xml
.idea/usage.statistics.xml
.idea/shelf/
.idea/.idea.iml

# IntelliJ 模块文件（Maven 项目由 pom.xml 驱动，.iml 是冗余）
*.iml

# 操作系统产生的垃圾文件
.DS_Store
Thumbs.db

# 日志
*.log
